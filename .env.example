# ============================================================
# 企业级 RAG Agent — 环境变量配置模板
# 复制为 .env 后填写实际值
# ============================================================

# --- LLM API 配置 (OpenAI 兼容接口) ---
LLM_API_BASE=http://localhost:8000/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# --- Embedding 模型 ---
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# --- Reranker 模型 ---
RERANKER_MODEL_NAME=BAAI/bge-reranker-large
RERANKER_DEVICE=cpu

# --- Redis 会话存储 ---
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=1800

# --- 数据库 (SQLite 开发 / PostgreSQL 生产) ---
DATABASE_URL=sqlite+aiosqlite:///data/rag_agent.db

# --- 鉴权 (JWT) ---
# 生产务必替换为 >=32 字节随机串: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- 检索配置 ---
BM25_TOP_K=20
FAISS_TOP_K=20
RERANK_TOP_K=10
MERGE_TOP_K=30

# --- 自省配置 ---
MAX_REFLECTION_ROUNDS=2
FACT_CHECK_CONFIDENCE_THRESHOLD=0.7

# --- 服务配置 ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
